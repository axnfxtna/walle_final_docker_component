FROM python:3.11.13

WORKDIR /app

ENV PYTHONPATH=/app
ENV KHANOMTAN_PATH=/app/models/KhanomTan-TTS-v1.0
# HuggingFace cache lives inside the mounted models volume so weights
# persist across image rebuilds and are not re-downloaded every time.
ENV HF_HOME=/app/models/hf_cache

# Copy TTS-specific setup script and requirements, then run setup
COPY setup-tts.sh requirements.txt ./
RUN bash setup-tts.sh

# Copy app code
COPY configs /app/configs
COPY src /app/src
COPY entrypoints /app/entrypoints
COPY .env .

CMD ["python", "entrypoints/entry_tts.py"]
